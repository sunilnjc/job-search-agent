# The `draft` command needs ONE of these providers configured.
# Priority: DRAFT_PROVIDER if set, else anthropic key, else openai key, else local ollama.
DRAFT_PROVIDER=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_DRAFT_MODEL=gpt-4o
OLLAMA_DRAFT_MODEL=llama3.2

# Optional: only needed for the Adzuna source. Get a free key at https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Optional: override the local Ollama models used for matching
OLLAMA_RANK_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
